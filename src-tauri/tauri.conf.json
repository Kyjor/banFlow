{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "banFlow",
  "version": "0.2.1",
  "identifier": "org.kyjor.banflow.tauri",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "banFlow",
        "width": 1920,
        "height": 1080,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "timer",
        "title": "Timer",
        "width": 350,
        "height": 250,
        "resizable": true,
        "alwaysOnTop": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
